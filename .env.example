# ============================================================
# GenZ IITian Connect — Environment Variables
# ============================================================

# App
NEXT_PUBLIC_APP_NAME="GenZ IITian Connect"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Socket.IO Server
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/genziitian_connect

# Redis (Matching Queue)
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
OTP_EXPIRY_SECONDS=300

# Email (OTP Delivery)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Supabase (Optional — if using Supabase Auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# WebRTC TURN Server
TURN_SERVER_URL=turn:your-turn-server.com:3478
TURN_USERNAME=your-turn-username
TURN_CREDENTIAL=your-turn-credential

# Compliance
GRIEVANCE_OFFICER_EMAIL=grievance@genziitian.com
PRIVACY_CONTACT_EMAIL=privacy@genziitian.com
